<!-- openvas-scan-config.xml -->

<create_config>
  <name>Lab Full and Fast - Custom</name>
  <comment>Full and fast scan for lab network with all NVT families enabled. Safe checks on.</comment>
  <copy>daba56c8-73ec-11df-a475-002264764cea</copy>

  <preference>
    <scanner_name>scanner</scanner_name>
    <name>scanner:Scanner Type</name>
    <value>OpenVAS Default</value>
  </preference>

  <preference>
    <scanner_name>scanner</scanner_name>
    <name>scanner:Port scan type</name>
    <value>SYN</value>
  </preference>

  <preference>
    <scanner_name>scanner</scanner_name>
    <name>scanner:Safe checks</name>
    <value>yes</value>
  </preference>

  <preference>
    <scanner_name>scanner</scanner_name>
    <name>scanner:Optimize the test</name>
    <value>yes</value>
  </preference>

  <preference>
    <scanner_name>scanner</scanner_name>
    <name>scanner:Max hosts</name>
    <value>10</value>
  </preference>

  <preference>
    <scanner_name>scanner</scanner_name>
    <name>scanner:Max checks</name>
    <value>5</value>
  </preference>

  <preference>
    <scanner_name>scanner</scanner_name>
    <name>scanner:Timeout</name>
    <value>60</value>
  </preference>

  <!-- Port list: All IANA assigned TCP + UDP -->
  <port_list id="33d0cd82-57c6-11e1-8ed1-406186ea4fc5"/>

  <!-- NVT Families — all enabled -->
